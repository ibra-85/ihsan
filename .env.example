AUTH_SECRET=e84181e2f33fa4004f53a904a327ccff101d82b108f63d01768b3ac9ece4459d

# CDN des PDFs (optionnel ; défaut : https://cdn.ihsan-coran.fr/coran)
# En production Vercel, on utilise généralement /pdf (proxy interne).
# NEXT_PUBLIC_CDN_URL=/pdf